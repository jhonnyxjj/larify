{
  "type": "module",
  "scripts": {
    "test": "bun --env-file=.env.test run test:prepare && bun --env-file=.env.test test --coverage",
    "test:prepare": "bunx prisma db push --force-reset --schema=prisma/schema.prisma",
    "dev": "bun tsoa:gen && bun run --watch src/index.ts",
    "build": "bun routes:gen && bun build",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write .",
    "pretty": "bun lint:fix && bun format",
    "commit": "bunx cz",
    "routes:gen": "tsoa routes",
    "doc:gen": "tsoa spec",
    "tsoa:gen": "bun routes:gen && bun doc:gen",
    "prisma:generate": "bunx prisma db push && bunx prisma generate",
    "migrate:create": "bunx prisma migrate dev --name ",
    "migrate:deploy": "bunx prisma migrate deploy",
    "migrate:reset": "bunx prisma migrate reset"
  },
  "dependencies": {
    "@prisma/client": "^6.16.3",
    "express": "^5.1.0",
    "pino": "^9.11.0",
    "reflect-metadata": "^0.2.2",
    "tsoa": "^6.6.0",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@types/express": "^5.0.3",
    "@types/node": "^24.5.2",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^8.44.0",
    "@typescript-eslint/parser": "^8.44.0",
    "bun-types": "^1.2.22",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "cz-emoji": "^1.3.2-canary.2",
    "eslint": "^9.36.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.6",
    "pino-pretty": "^13.1.1",
    "prettier": "^3.6.2",
    "prisma": "^6.16.3",
    "supertest": "^7.1.4",
    "typescript": "^5.9.2"
  },
  "config": {
    "commitizen": {
      "path": "cz-emoji"
    }
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "bunx eslint --fix",
      "bunx prettier --write"
    ],
    "*.{js,json,md}": [
      "bunx prettier --write"
    ]
  }
}