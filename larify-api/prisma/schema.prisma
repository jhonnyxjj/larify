// =========================
// ⚠️ NOTE:
// Sempre rode o comando `bun prisma:generate` após editar este arquivo.
// =========================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("LARIFY_DATABASE_URL")
}

// =========================
//  ENUMS
// =========================
enum UserRole {
  USER
  ADMIN
}

enum PropertyType {
  SALE    // venda
  RENT    // aluguel
}

enum PropertyStatus {
  ACTIVE
  INACTIVE
  SOLD
}

// =========================
//  MODELS / TABELAS
// =========================

model User {
  id              String      @id @default(cuid())                     // ID interno
  authProviderId  String      @unique @map("auth_provider_id")        // UID vindo do Firebase Auth
  name            String
  email           String      @unique
  phone           String?                                         // opcional (para contato)
  role            UserRole    @default(USER)
  
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")
  lastLoginAt     DateTime    @map("last_login_at")

  // Relacionamentos
  properties      Property[]

  @@map("users")
}

model Property {
  id            String          @id @default(cuid())
  title         String
  description   String
  price         Decimal
  type          PropertyType
  status        PropertyStatus  @default(ACTIVE)
  
  // Endereço
  city          String
  neighborhood  String
  street        String
  number        String
  cep           String
  reference     String?          // ponto de referência opcional

  // Relacionamento
  userId        String           @map("user_id")
  user          User             @relation(fields: [userId], references: [id])
  
  images        PropertyImage[]

  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("properties")
}

model PropertyImage {
  id          String    @id @default(cuid())
  url         String    // URL da foto (Firebase Storage, Cloudinary, etc)
  
  propertyId  String    @map("property_id")
  property    Property  @relation(fields: [propertyId], references: [id])

  @@map("property_images")
}
